// Prisma schema for Jurídico ADV
// Auth: NextAuth v5 with Credentials provider
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH — NextAuth v5 compatible + custom fields
// ============================================================
model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  emailVerified DateTime? @map("email_verified")
  image        String?
  passwordHash String?   @map("password_hash")
  role         Role      @default(ADVOGADO)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  accounts  Account[]
  sessions  Session[]
  processos Processo[] @relation("AdvogadoProcessos")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  ADMIN
  ADVOGADO
}

// ============================================================
// DOMAIN MODELS
// ============================================================
model Cliente {
  id          String   @id @default(cuid())
  nome        String
  cpfCnpj     String?  @unique @map("cpf_cnpj")
  email       String?
  telefone    String?
  observacoes String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  processos Processo[]

  @@index([nome])
  @@map("clientes")
}

model Processo {
  id          String          @id @default(cuid())
  numero      String          @unique
  tribunal    Tribunal
  vara        String?
  area        String?
  status      StatusProcesso  @default(ATIVO)
  clienteId   String          @map("cliente_id")
  advogadoId  String?         @map("advogado_id")
  observacoes String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  cliente    Cliente     @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  advogado   User?       @relation("AdvogadoProcessos", fields: [advogadoId], references: [id], onDelete: SetNull)
  andamentos Andamento[]
  documentos Documento[]

  @@index([clienteId])
  @@index([advogadoId])
  @@index([tribunal])
  @@index([status])
  @@map("processos")
}

enum Tribunal {
  TJSC
  TJRS
  TJPR
  TJSP
  TJRJ
  TJMG
  TJGO
  TJPA
  OUTRO
}

enum StatusProcesso {
  ATIVO
  ARQUIVADO
  SUSPENSO
  ENCERRADO
}

model Andamento {
  id         String         @id @default(cuid())
  processoId String         @map("processo_id")
  externalId String         @unique @map("external_id")
  data       DateTime
  tipo       String
  descricao  String
  fonte      FonteAndamento @default(MANUAL)
  hash       String?        @unique
  createdAt  DateTime       @default(now()) @map("created_at")

  processo   Processo    @relation(fields: [processoId], references: [id], onDelete: Cascade)
  documentos Documento[]

  @@index([processoId])
  @@index([data(sort: Desc)])
  @@index([processoId, externalId])
  @@map("andamentos")
}

enum FonteAndamento {
  MANUAL
  SCRAPER
  IMPORTACAO
}

model Documento {
  id           String   @id @default(cuid())
  externalId   String   @unique @map("external_id")
  andamentoId  String?  @map("andamento_id")
  processoId   String   @map("processo_id")
  nome         String
  storagePath  String?  @map("storage_path")
  tipo         String?
  tamanhoBytes BigInt?  @map("tamanho_bytes")
  createdAt    DateTime @default(now()) @map("created_at")

  andamento Andamento? @relation(fields: [andamentoId], references: [id], onDelete: SetNull)
  processo  Processo   @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@index([andamentoId])
  @@index([processoId])
  @@index([processoId, externalId])
  @@map("documentos")
}
