# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=juridico
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=juridico_adv

# DATABASE_URL é montada automaticamente pelo docker-compose usando as vars acima
# Não precisa preencher aqui — o compose monta: postgresql://USER:PASS@postgres:5432/DB

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET=GERE_COM_openssl_rand_base64_32
AUTH_URL=https://SEU_DOMINIO

# ── E-PROC TJSC ──────────────────────────────────────────────────────────────
EPROC_TRIBUNAL=TJSC
EPROC_TJSC_USER=SEU_USUARIO
EPROC_TJSC_PASSWORD=SUA_SENHA
EPROC_TJSC_TOTP_SEED=XXXX XXXX XXXX XXXX XXXX XXXX XXXX XXXX

# ── E-PROC TJRS ──────────────────────────────────────────────────────────────
EPROC_TJRS_USER=SEU_USUARIO
EPROC_TJRS_PASSWORD=SUA_SENHA
EPROC_TJRS_TOTP_SEED=XXXX XXXX XXXX XXXX XXXX XXXX XXXX XXXX

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_ARCHIVE_DIR=/app/storage/archive
PIPELINE_INTERVAL_MS=21600000
